{
  "apiVersion": 2,
  "id": "garret.adb-devices",
  "publisher": "garret",
  "name": "Android Device Management",
  "version": "0.1.0",
  "description": "List, mirror, and control connected Android devices over adb + scrcpy.",
  "icon": "icon.svg",
  "readme": "README.md",
  "widgets": [
    {
      "id": "devices",
      "name": "Device control",
      "ui": "dist/devices",
      "host": "dist/host/index.cjs",
      "capabilities": ["process", "windows"],
      "defaultSize": { "w": 6, "h": 5 },
      "surfaces": {
        "device-mirror": {
          "name": "Device Mirror",
          "ui": "dist/mirror",
          "frame": false,
          "transparent": true,
          "defaultSize": { "w": 360, "h": 760 },
          "minSize": { "w": 180, "h": 380 }
        }
      }
    }
  ]
}
