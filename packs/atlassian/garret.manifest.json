{
  "apiVersion": 2,
  "id": "garret.atlassian",
  "publisher": "garret",
  "name": "Atlassian",
  "version": "1.8.0",
  "description": "Jira issues and Bitbucket pull requests. One account, per-product tokens.",
  "icon": "icon.svg",
  "readme": "README.md",
  "shared": {
    "settings": {
      "schema": [
        {
          "key": "email",
          "label": "Email",
          "type": "string",
          "placeholder": "you@company.com"
        },
        {
          "key": "jiraSite",
          "label": "Jira site",
          "type": "string",
          "placeholder": "your-domain.atlassian.net"
        },
        {
          "key": "jiraToken",
          "label": "Jira API token",
          "type": "secret",
          "placeholder": "id.atlassian.com token"
        },
        {
          "key": "bitbucketToken",
          "label": "Bitbucket token",
          "type": "secret",
          "placeholder": "Bitbucket API token / app password"
        },
        {
          "key": "bgNotify",
          "label": "Background notifications",
          "type": "boolean",
          "default": false
        }
      ]
    }
  },
  "widgets": [
    {
      "id": "jira",
      "name": "Jira Tickets",
      "ui": "dist/jira",
      "capabilities": [
        "secrets",
        "openExternal",
        "network:*.atlassian.net",
        "notify"
      ],
      "defaultSize": {
        "w": 5,
        "h": 7
      },
      "minSize": {
        "w": 3,
        "h": 3
      },
      "notifier": {
        "auth": { "type": "basic", "user": "{shared.email}", "pass": "{secret.jiraToken}" },
        "request": {
          "url": "https://{shared.jiraSite}/rest/api/3/search/jql",
          "method": "POST",
          "headers": { "Accept": "application/json", "Content-Type": "application/json" },
          "body": "{\"jql\":\"assignee = currentUser() AND statusCategory != Done ORDER BY created DESC\",\"maxResults\":20,\"fields\":[\"summary\"]}"
        },
        "itemsPath": "issues",
        "idField": "key",
        "titleTemplate": "New Jira ticket: {item.key}",
        "bodyTemplate": "{item.fields.summary}",
        "urlTemplate": "https://{shared.jiraSite}/browse/{item.key}",
        "intervalMin": 5
      }
    },
    {
      "id": "pull-requests",
      "name": "Pull Requests",
      "ui": "dist/prs",
      "capabilities": [
        "secrets",
        "openExternal",
        "network:*.atlassian.net",
        "network:api.bitbucket.org",
        "notify"
      ],
      "defaultSize": {
        "w": 5,
        "h": 8
      },
      "minSize": {
        "w": 3,
        "h": 4
      }
    }
  ]
}
