{
  "apiVersion": 2,
  "id": "garret.bitbucket",
  "publisher": "garret",
  "name": "Bitbucket",
  "version": "1.0.0",
  "description": "Your open Bitbucket pull requests.",
  "widgets": [
    {
      "id": "prs",
      "name": "My Pull Requests",
      "ui": "dist/prs",
      "capabilities": ["secrets", "network:api.bitbucket.org"],
      "defaultSize": { "w": 5, "h": 6 },
      "settings": {
        "schema": [
          { "key": "email", "label": "Email", "type": "string", "placeholder": "you@company.com" },
          { "key": "token", "label": "API token", "type": "secret", "placeholder": "Atlassian API token (id.atlassian.com)" }
        ]
      }
    }
  ]
}
