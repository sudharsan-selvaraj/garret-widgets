{
  "apiVersion": 2,
  "id": "demo.sticky-note",
  "publisher": "demo",
  "name": "Sticky Note",
  "version": "1.0.0",
  "description": "A quick jot pad that saves as you type.",
  "widgets": [
    {
      "id": "note",
      "name": "Sticky Note",
      "ui": "dist/note",
      "capabilities": [],
      "defaultSize": { "w": 4, "h": 4 },
      "settings": {
        "schema": [
          {
            "key": "accent",
            "label": "Accent",
            "type": "select",
            "options": ["yellow", "blue", "pink", "green"],
            "default": "yellow"
          }
        ]
      }
    }
  ]
}
